<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Commerce Risk Analytics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <linnk href="/styles.css" rel="stylesheet">
</head>

<body>

    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark px-4">
        <div class="container-fluid">

            <!-- Brand -->
            <a class="navbar-brand fw-bold" href="/">
                🛡️ E-Commerce Risk Analytics
            </a>

            <!-- Right side links — only show when NOT logged in -->
            <% if (!locals.user) { %>
                <ul class="navbar-nav flex-row gap-3">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/auth/login">Login</a>
                    </li>
                </ul>
                <% } %>

                    <!-- Right side — show when logged IN -->
                    <% if (locals.user) { %>
                        <ul class="navbar-nav flex-row gap-3 align-items-center">
                            <li class="nav-item">
                                <span class="text-secondary small">Logged in as <strong class="text-white">
                                        <%= user.username %>
                                    </strong></span>
                            </li>
                            <li class="nav-item">
                                <form action="/auth/logout" method="POST">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Logout</button>
                                </form>
                            </li>
                        </ul>
                        <% } %>

        </div>
    </nav>